<div class="col-md-6">
  <div class="card h-100">
    <div class="card-header d-flex justify-content-between align-items-center">
      <div class="d-flex align-items-center">
        <i class="bi bi-display me-2 text-primary fs-5" aria-hidden="true"></i>
        <h2 class="h5 mb-0">Active Sessions</h2>
      </div>
    </div>
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-sm align-middle">
          <tbody>
            <% sessions.each do |session| %>
              <%= render "users/sessions/session_row", session: session, current_sid: current_sid %>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
    <% other_count = sessions.count { |s| s[:sid] != current_sid } %>
    <div class="card-footer bg-transparent d-flex justify-content-end">
      <%= button_to "Sign Out Other Sessions", all_sessions_user_path,
                    method: :delete,
                    class: "btn btn-warning #{'disabled' if other_count == 0}",
                    disabled: other_count == 0,
                    data: { turbo_stream: true } %>
    </div>
  </div>
</div>