<% set_meta_tags title: "Character Management" %>

<% content_for(:page_header) do %>
  <div>
    <h1>Character Management</h1>
    <p><%= FFXIV::Character.count %> tracked characters</p>
  </div>
<% end %>

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-body">
        <%= form_with url: admin_characters_path, method: :get, class: "mb-3" do |f| %>
          <div class="input-group">
            <%= f.text_field :q, value: params[:q], placeholder: "Search characters...",
                class: "form-control", "aria-label": "Search characters" %>
            <%= f.submit "Search", class: "btn btn-outline-secondary" %>
          </div>
        <% end %>
        <% if params[:q].present? %>
          <p class="text-muted">Showing <%= pluralize(@pagy.count, "search result") %>...</p>
        <% end %>

        <table class="table table-hover">
          <thead>
          <tr>
            <th></th>
            <th scope="col">Lodestone ID</th>
            <th scope="col">Name</th>
            <th scope="col">Home World</th>
            <th scope="col">Registrations</th>
            <th scope="col">Creation Date</th>
            <th scope="col">Last Update</th>
          </tr>
          </thead>
          <tbody>
          <% @characters.each do |character| %>
            <tr>
              <td><%= image_tag character.avatar_url, class: "rounded", size: 28 %></td>
              <td><%= link_to character.lodestone_id, admin_character_path(character.lodestone_id) %></td>
              <td>
                <%= character.name %>
                <% if character.verified? %>
                  <i class="bi bi-patch-check-fill text-success" title="Verified Character"></i>
                <% end %>
                <% if character.ban.present? %>
                  <i class="bi bi-slash-circle text-danger" title="Banned Character"></i>
                <% end %>
                <% if character.refresh_fail_reason.present? %>
                  <i class="bi bi-exclamation-circle text-warning" title="<%= I18n.t "character_registrations.refresh_fail_reasons.#{character.refresh_fail_reason}" %>"></i>
                <% end %>
              </td>
              <td><%= character.home_with_datacenter %></td>
              <td><%= character.character_registrations.size %></td>
              <td><span data-controller="utilities--hover-dt"
                    data-utilities--hover-dt-ts-value="<%= character.created_at.to_i %>"
                    data-utilities--hover-dt-format-value="adaptive"><%= character.created_at %></span></td>
              <td><span data-controller="utilities--hover-dt"
                    data-utilities--hover-dt-ts-value="<%= character.updated_at.to_i %>"
                    data-utilities--hover-dt-format-value="adaptive"><%= character.updated_at %></span></td>
            </tr>
          <% end %>
          </tbody>
        </table>

        <%== @pagy.series_nav(:bootstrap) %>
      </div>
    </div>
  </div>
</div>