<% content_for :page_layout do %>
  <% if user_signed_in? %>
    <%= render 'layouts/portal/navigation/sidebar' %>
  <% end %>

  <main class="main-content">
    <div class="position-relative">
      <% if user_signed_in? %>
        <%= render 'layouts/portal/navigation/topbar' %>
      <% else %>
        <nav class="navbar navbar-expand-xl navbar-light">
          <div class="container-fluid navbar-inner">
            <div class="navbar-brand pride-logo-container">
              <%= image_tag asset_path('logos/xivauth-logo-45.svg'), style: "height: 1.5em;" %>
              <a class="pride-logo-icon <%= current_pride_flag_class %> pride-logo-mask" href="/" id="sidebarLabel"></a>
            </div>
            <ul class="navbar-nav align-items-center navbar-list d-none d-xl-flex">
              <li class="nav-item">
                <%= link_to new_user_registration_path, class: "nav-link" do %>
                  Sign Up
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to new_user_session_path, class: "btn btn-primary nav-link" do %>
                  Log In
                <% end %>
              </li>
            </ul>
          </div>
        </nav>
      <% end %>
    </div>
    <%= content_for?(:marketing_page_content) ?  yield(:marketing_page_content) : yield %>
  </main>
<% end %>

<%= render template: "layouts/application" %>