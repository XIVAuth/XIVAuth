<% content_for :head_extensions do %>
  <%= stylesheet_link_tag "special/oauth-consent" %>
<% end %>


<% content_for :page_layout do %>
  <div class="wrapper">
    <% if (bg = @client_application&.can_use_custom_background? && @client_application.oauth_background) %>
      <div class="oauth-consent-backdrop full-backdrop" style="background-image: url('<%= bg.url(derivative: :hd) %>')"></div>
    <% else %>
      <div class="oauth-consent-backdrop full-backdrop"></div>
    <% end %>
    <section class="oauth-content">
      <div class="row m-0 align-items-center justify-content-center vh-100 w-100">
        <div class="mw-sm">
          <div class="card my-4 frost-background-filter">
            <%= yield %>
          </div>
        </div>
      </div>
    </section>
  </div>
<% end %>

<%= render template: "layouts/application" %>