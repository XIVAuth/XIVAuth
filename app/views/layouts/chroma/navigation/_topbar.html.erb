<nav class="navbar navbar-expand bg-dark" data-bs-theme="dark">
  <div class="container-fluid navbar-inner">
    <% if user_signed_in? %>
      <button class="navbar-toggler d-xl-none pe-3" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebar"
              aria-controls="sidebar" aria-label="Toggle navigation">
        <i class="bi bi-list"></i>
      </button>
    <% end %>

    <div class="navbar-brand pride-logo-container">
      <%= image_tag asset_path('logos/xivauth-logo-45.svg'), style: "height: 1.5em;" %>
      <a class="pride-logo-icon <%= current_pride_flag_class %> pride-logo-mask" href="/" id="sidebarLabel"></a>
    </div>

    <ul class="navbar-nav ms-auto align-items-center navbar-list mb-lg-0">
      <% if user_signed_in? %>
        <li class="nav-item dropdown">
          <a id="navbarDropdown" class="py-0 nav-link d-flex align-items-center gap-1" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <img src="<%= current_user.avatar_url %>" alt="" width="36" height="36" class="d-inline-block rounded-2">
            <div class="caption ms-2 d-none d-md-block">
              <h6 class="mb-0">Hi, <%= current_user&.profile&.display_name || 'Guest' %>!</h6>
            </div>
            <i class="bi bi-chevron-down" style="font-size: 0.65em;"></i>
          </a>
          <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
            <li>
              <a class="dropdown-item" href="<%= edit_user_path %>">
                <span class="d-block">
                  <i class="bi bi-person me-2"></i> Profile
                </span>
              </a>
            </li>
            <li>
              <%= link_to destroy_user_session_path, class: "dropdown-item text-danger", data: { "turbo-method": :delete } do %>
                <span class="d-block">
                  <i class="bi bi-box-arrow-left me-2"></i> Log Out
                </span>
              <% end %>
            </li>
          </ul>
        </li>
      <% else %>
        <li class="nav-item d-none d-md-block">
          <%= link_to "Sign Up", new_user_registration_path, class: "nav-link" %>
        </li>
        <li class="nav-item d-none d-md-block">
          <%= link_to "Log In", new_user_session_path, class: "btn btn-primary nav-link btn-sm border-0" %>
        </li>
        <li class="nav-item dropdown d-md-none">
          <a class="py-0 nav-link d-flex align-items-center gap-1" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-person-circle fs-4"></i>
            <i class="bi bi-chevron-down" style="font-size: 0.65em;"></i>
          </a>
          <ul class="dropdown-menu dropdown-menu-end">
            <li>
              <%= link_to new_user_registration_path, class: "dropdown-item" do %>
                <span class="d-block">
                  <i class="bi bi-person-plus me-2"></i> Sign Up
                </span>
              <% end %>
            </li>
            <li>
              <%= link_to new_user_session_path, class: "dropdown-item" do %>
                <span class="d-block">
                  <i class="bi bi-box-arrow-in-right me-2"></i> Log In
                </span>
              <% end %>
            </li>
          </ul>
        </li>
      <% end %>
    </ul>
  </div>
</nav>
