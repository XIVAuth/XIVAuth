<%= form_with(url: other_sessions_user_path, method: :delete) do |f| %>
  <%= f.hidden_field :confirmed, value: "1" %>
  <div class="modal-header">
    <h5 class="modal-title">Sign Out Other Sessions</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
  </div>
  <div class="modal-body">
    <% if other_session_count > 0 %>
      <p>
        You have <strong><%= pluralize(other_session_count, 'other active session') %></strong>.
        Continuing will sign you out of all of them immediately. Your current session will not be affected.
      </p>
    <% else %>
      <p>You have no other active sessions to sign out of.</p>
    <% end %>
  </div>
  <div class="modal-footer">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
    <%= f.submit "Sign Out Other Sessions", class: "btn btn-warning", disabled: other_session_count == 0 %>
  </div>
<% end %>

