<% set_meta_tags title: "What are certificates?",
                 description: "A primer on certificates, how they work, when to use them, and important information " \
                   "on what it means to use them in a project."
%>

<% content_for(:page_header) do %>
  <div>
    <h1>About XIVAuth Certificates</h1>
    <p>Certificates are an advanced feature. Most users will never need them.</p>
  </div>
<% end %>

<ul class="nav nav-tabs nav-justified mb-4" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link active" id="users-tab" data-bs-toggle="tab" data-bs-target="#users-tab-pane"
            type="button" role="tab" aria-controls="users-tab-pane" aria-selected="true">
