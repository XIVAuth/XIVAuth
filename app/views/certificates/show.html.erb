<% set_meta_tags title: "Certificate Details" %>

<% content_for(:page_header) do %>
  <div class="d-flex justify-content-between align-items-center">
    <div>
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
          <li class="breadcrumb-item"><%= link_to "My Certificates", certificates_path %></li>
          <li class="breadcrumb-item active" aria-current="page">Certificate Details</li>
        </ol>
      </nav>
      <h1>Certificate Details</h1>
    </div>
    <div class="d-flex gap-2">
      <% if @certificate.active? %>
        <%= button_to revoke_certificate_path(@certificate), method: :post, class: "btn btn-danger",
                      data: { turbo_stream: "remote_modal" } do %>
          <i class="bi bi-shield-x"></i> Revoke
        <% end %>
      <% end %>
      <% if Rails.env.development? %>
        <%= button_to destroy_certificate_path(@certificate), method: :delete, class: "btn btn-danger" do %>
          <i class="bi bi-trash"></i> Delete
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<div class="row">
  <div class="col-lg-6">
    <div class="card mb-4">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="mb-0"><i class="bi bi-award"></i> Certificate Info</h3>
        <% if @certificate.revoked? %>
          <span class="badge bg-danger">Revoked</span>
        <% elsif @certificate.expired? %>
          <span class="badge bg-secondary">Expired</span>
        <% else %>
          <span class="badge bg-success">Active</span>
        <% end %>
      </div>
      <div class="card-body">
        <table class="table table-sm table-borderless">
          <tr>
            <th class="text-muted fw-normal">Serial (UUID)</th>
            <td><code><%= @certificate.id %></code></td>
          </tr>
          <tr>
            <th class="text-muted fw-normal">Subject</th>
            <td>
              <% if @certificate.subject_type == "User" %>
                <i class="bi bi-person-fill"></i> <%= @certificate.subject.display_name %>
              <% elsif @certificate.subject_type == "CharacterRegistration" %>
                <i class="bi bi-person-badge"></i> <%= @certificate.subject.character.name %>
                <span class="text-muted small">(<%= @certificate.subject.character.home_with_datacenter %>)</span>
              <% end %>
            </td>
          </tr>
          <tr>
            <th class="text-muted fw-normal">Issued At</th>
            <td><span data-controller="utilities--hover-dt"
                                   data-utilities--hover-dt-ts-value="<%= @certificate.issued_at.to_i %>"
                                   data-utilities--hover-dt-format-value="datetime"><%= @certificate.issued_at.to_fs(:long) %></span></td>
          </tr>
          <tr>
            <th class="text-muted fw-normal">Expires At</th>
            <td><span data-controller="utilities--hover-dt"
                                   data-utilities--hover-dt-ts-value="<%= @certificate.expires_at.to_i %>"
                                   data-utilities--hover-dt-format-value="datetime"><%= @certificate.expires_at.to_fs(:long) %></span></td>
          </tr>
          <% if @certificate.revoked? %>
            <tr>
              <th class="text-muted fw-normal">Revoked At</th>
              <td>
                <%= @certificate.revoked_at.to_fs(:long) %>
                <span class="text-muted small">(<%= @certificate.revocation_reason.humanize %>)</span>
              </td>
            </tr>
          <% end %>
          <tr>
            <th class="text-muted fw-normal">Key Type</th>
            <td>
              <%= @certificate.key_type %>
              <% if @certificate.key_curve.present? %>
                (<%= @certificate.key_curve %>)
              <% else %>
                <%= @certificate.key_bits %>-bit
              <% end %>
            </td>
          </tr>
          <tr>
            <th class="text-muted fw-normal">Certificate Fingerprint</th>
            <td><pre class="mb-0"><code><%= format_fingerprint(@certificate.certificate_fingerprint) %></code></pre></td>
          </tr>
          <tr>
            <th class="text-muted fw-normal">Public Key Fingerprint</th>
            <td><pre class="mb-0"><code><%= format_fingerprint(@certificate.public_key_fingerprint) %></code></pre></td>
          </tr>
          <tr>
            <th class="text-muted fw-normal">Issuing CA</th>
            <td>
              <code class="me-2"><%= @certificate.certificate_authority.slug %></code>
              <%= render "certificates/certificate_authorities/ca_download_links", ca: @certificate.certificate_authority %>
            </td>
          </tr>
          <% if @certificate.requesting_application.present? %>
            <tr>
              <th class="text-muted fw-normal">Requested by</th>
              <td><%= @certificate.requesting_application.name %></td>
            </tr>
          <% end %>
        </table>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="card mb-4">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="mb-0"><i class="bi bi-file-text"></i> Certificate Data</h3>
        <div class="btn-toolbar gap-2">
          <%= link_to certificate_path(@certificate, format: :pem), class: "btn btn-primary" do %>
            <i class="bi bi-download"></i> PEM
          <% end %>
          <%= link_to certificate_path(@certificate, format: :der), class: "btn btn-outline-primary" do %>
            <i class="bi bi-download"></i> DER
          <% end %>
        </div>
      </div>
      <div class="card-body">
        <pre class="bg-body-secondary p-2 rounded small overflow-auto mb-0"><code><%= @certificate.certificate_pem.strip %></code></pre>
      </div>
    </div>
  </div>
</div>
