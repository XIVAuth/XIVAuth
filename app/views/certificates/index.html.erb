<% set_meta_tags title: "My Certificates" %>

<% content_for(:page_header) do %>
  <div class="d-flex justify-content-between align-items-center">
    <h1>My Certificates</h1>
    <div class="d-flex gap-2">
      <% if Flipper.enabled?(:certificate_management, current_user) %>
        <%= link_to new_certificate_request_path, class: "btn btn-primary",
              data: { turbo_stream: "remote_modal" } do %>
          <i class="bi bi-plus"></i> Request Certificate
        <% end %>
      <% end %>
      <%= link_to ca_certs_path, class: "btn btn-secondary" do %>
        <i class="bi bi-shield-lock"></i> Certificate Authorities
      <% end %>
    </div>
  </div>
  <div>
    <p>
      X.509-compliant certificates issued to your account and verified characters.
      <%= link_to why_certificates_path do %>
        <span class="small">(Why use this?)</span>
      <% end %>
    </p>
  </div>
<% end %>

<% if @certificates.empty? %>
  <div class="row">
    <div class="col-12">
      <div class="card">
        <div class="card-body text-center text-muted py-5">
          <i class="bi bi-patch-exclamation display-4 mb-3 d-block"></i>
          <p class="mb-0">You have no certificates yet.</p>
          <% if Flipper.enabled?(:certificate_management, current_user) %>
            <p class="small mb-0">
              <%= link_to "Request a certificate", new_certificate_request_path,
                    data: { turbo_stream: "remote_modal" } %> to get started.
            </p>
          <% else %>
            <p class="small mb-0">Certificates may not be requested at this time.</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% else %>
  <div class="row">
    <% @certificates.each do |certificate| %>
      <%= render 'certificate_card', certificate: certificate %>
    <% end %>
  </div>
<% end %>
