POSTGRES_DB=xivauth
POSTGRES_USER=xivauth
POSTGRES_PASSWORD=ThisIsABadPassword

# Set to false to use in-memory job processing.
DEV_USE_SIDEKIQ=true

### Developing outside of Docker? These might be helpful!
# POSTGRES_HOST=localhost
# REDIS_URL=redis://localhost:6379 # note: no server ID, XIVAuth will allocate servers for its own purposes.
